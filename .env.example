# Production environment template
# Copy to .env on the server and replace all placeholder values.

ENVIRONMENT=production

# RDS PostgreSQL (use sslmode=require for AWS RDS)
DATABASE_URL=postgresql+psycopg2://app_user:CHANGE_ME@your-rds-endpoint.region.rds.amazonaws.com:5432/marketplace_db?sslmode=require

# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

# Public frontend URL (used in password reset emails)
FRONTEND_URL=https://app.example.com

# Comma-separated allowed browser origins
CORS_ORIGINS=https://app.example.com

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://app.example.com/auth/callback

# Email (SMTP)
email_user=noreply@example.com
email_pass=your_smtp_app_password

# Optional
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
